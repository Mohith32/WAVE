# ============================================================
# WAVE backend — environment variables
# Copy to .env for local dev; set in Render/Fly dashboard for deploy
# NEVER commit .env — only commit this example file.
# ============================================================

# --- Database (PostgreSQL) ---
# Supabase: Settings -> Database -> Connection string (Direct)
DB_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres
DB_USERNAME=postgres
DB_PASSWORD=<your-postgres-password>
DB_POOL_MAX=20
DB_POOL_MIN_IDLE=5

# --- Redis (Upstash recommended; free tier 10k cmd/day) ---
# Upstash: Console -> Database -> REST/TCP endpoint
REDIS_HOST=<your>.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=<your-redis-password>
REDIS_SSL=true

# --- JWT ---
# MUST be at least 64 characters for HS512. Generate: `openssl rand -base64 64`
JWT_SECRET=CHANGE_ME_TO_AT_LEAST_64_RANDOM_CHARACTERS_FOR_HS512_SIGNING_xxxxxxxxx
JWT_EXPIRATION=86400000

# --- File storage ---
# Backend options: "supabase" (recommended for free deploys) or "local" (dev only — lost on restart)
STORAGE_BACKEND=supabase

# Supabase Storage (if STORAGE_BACKEND=supabase)
# 1) Create a bucket named `wave-uploads` in Supabase Storage
# 2) Mark as Public (or keep private + use signed URLs)
# 3) Get SERVICE_ROLE key (NOT anon key) from Settings -> API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key>
SUPABASE_BUCKET=wave-uploads
SUPABASE_PUBLIC_BUCKET=true

# Local dev only (STORAGE_BACKEND=local)
LOCAL_UPLOAD_DIR=./uploads

# --- CORS ---
# Comma-separated list; use "*" for dev only
CORS_ALLOWED_ORIGINS=*

# --- Rate limiting (requests per refill window) ---
RL_AUTH_CAPACITY=10
RL_AUTH_REFILL=60
RL_UPLOAD_CAPACITY=30
RL_UPLOAD_REFILL=60

# --- Server tuning ---
PORT=8080
TOMCAT_THREADS_MAX=200
TOMCAT_THREADS_MIN=20

# --- Logging ---
LOG_LEVEL=INFO
APP_LOG_LEVEL=INFO
JPA_SHOW_SQL=false
JPA_DDL=update
FLYWAY_ENABLED=false
